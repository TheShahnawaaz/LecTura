{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "LecTura",
    "version": "../package.json"
  },
  "tauri": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/TheShahnawaaz/LecTura/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCRjEwODg0MzZDQzkyMTcKUldRWGtzdzJoQWp4cXhUb1ZuVExVY01VSklDbWxsekt6aUVnZzVZMHNEMVc1NmlkYWFYdU52WGwK",
      "dialog": true
    },
    "allowlist": {
      "all": false,
      "fs": {
        "all": true,
        "scope": ["$APPDIR/**", "$APPDATA/**"]
      },
      "protocol": {
        "asset": true,
        "assetScope": ["$APPDIR/**", "$APPDATA/**"]
      },
      "shell": {
        "all": false,
        "open": true,
        "execute": true,
        "sidecar": true
      },
      "window": {
        "all": false,
        "setFullscreen": true
      }
    },
    "windows": [
      {
        "title": "LecTura",
        "width": 1200,
        "height": 800,
        "fileDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.lectura.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [
        "bin/yt-dlp"
      ]
    }
  }
}
